# AI Memory Layer — Unified Environment
# =============================================================================
# Единый .env для OB1 (knowledge base) + Honcho (user model).
# Один PostgreSQL, один эмбеддер, один LLM-ключ.
# Вендор-агностик: DeepSeek по умолчанию, но заменимо на любой OpenAI-совместимый API.
#
# Порядок:
#   1. Скопировать этот файл в .env
#   2. Заменить *** на реальные значения
#   3. Выбрать DOMAIN (см. ниже)
#   4. docker compose up -d

# =============================================================================
# Домен (определяет URL всех сервисов)
# =============================================================================
# Три сценария — раскомментируй нужный:
#
# 1. Рабочая станция (только localhost):
DOMAIN=localhost
#
# 2. Локальная сеть (доступ с других машин):
# DOMAIN=ai.local
#   → добавить на клиентах в /etc/hosts: <IP-сервера> ai.local
#
# 3. Локальная сеть без DNS (по IP):
# DOMAIN=<IP-сервера>
#   → прямой доступ по IP, работает из коробки
#
# По умолчанию Caddy работает на HTTP (порт 80 внутри контейнера).
# Как включить TLS — см. README, раздел «Настройка TLS».

# =============================================================================
# Версии образов (менять при обновлении)
# =============================================================================
IMAGE_PGVECTOR=pgvector/pgvector:pg17
IMAGE_REDIS=redis:8.2
IMAGE_INFINITY=michaelf34/infinity:0.0.77-cpu
IMAGE_CADDY=caddy:2-alpine
CADDY_HTTP_PORT=80
# Порт 80 внутри контейнера. На хосте маппится через docker compose ports.
# Для нестандартного порта (например, 8080) — изменить здесь.
# Caddy внутри контейнера всегда слушает порт 80.
# Доступ: http://<DOMAIN>:<CADDY_HTTP_PORT>

# =============================================================================
# LLM (OpenAI-совместимый API)
# =============================================================================
# По умолчанию DeepSeek. Для другого провайдера — поменять URL и модель.

LLM_API_KEY=***
# ВАЖНО: URL без /v1 на конце — compose добавляет его автоматически.
# DeepSeek: https://api.deepseek.com
# OpenRouter: https://openrouter.ai/api
# OpenAI: https://api.openai.com
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
# deepseek-v4-pro поддерживает structured output (json_schema) — нужно deriver.
# deepseek-chat поддерживает tool calling — нужно dialectic.
# Если модель не поддерживает json_schema, deriver автоматически переходит на json_object режим.
DERIVER_MODEL=deepseek-v4-pro

# =============================================================================
# Эмбеддинги
# =============================================================================

EMBEDDING_MODEL=deepvk/USER-bge-m3

# =============================================================================
# PostgreSQL (единый, базы ob1 + honcho)
# =============================================================================

PG_SUPERUSER_PASSWORD=***
OB1_DB_PASSWORD=***
HONCHO_DB_PASSWORD=***

# =============================================================================
# OB1 — Knowledge Base
# =============================================================================

OB1_MCP_ACCESS_KEY=***
# openssl rand -hex 32
OB1_CITATION_URL=http://localhost/ob1
# Для LAN/VPS: замени localhost на значение DOMAIN (например, http://ai.local/ob1)

# =============================================================================
# Honcho — User Model
# =============================================================================

HONCHO_REDIS_PASSWORD=***
HONCHO_JWT_SECRET=***
HONCHO_API_KEY=***

# =============================================================================
# Общие
# =============================================================================

LOG_LEVEL=INFO
