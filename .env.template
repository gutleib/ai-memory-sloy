# AI Memory Layer — Unified Environment
# =============================================================================
# Единый .env для OB1 (knowledge base) + Honcho (user model).
# Один PostgreSQL, один эмбеддер, один LLM-ключ.
# Вендор-агностик: DeepSeek по умолчанию, но заменимо на любой OpenAI-совместимый API.
#
# Порядок:
#   1. Скопировать этот файл в .env
#   2. Заменить *** на реальные значения
#   3. docker compose up -d

# =============================================================================
# LLM (OpenAI-совместимый API)
# =============================================================================
# По умолчанию DeepSeek. Для другого провайдера — поменять URL и модель.

LLM_API_KEY=***
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# =============================================================================
# Эмбеддинги
# =============================================================================

EMBEDDING_MODEL=deepvk/USER-bge-m3

# =============================================================================
# PostgreSQL (единый, базы ob1 + honcho)
# =============================================================================

PG_SUPERUSER_PASSWORD=***
OB1_DB_PASSWORD=***
HONCHO_DB_PASSWORD=***

# =============================================================================
# OB1 — Knowledge Base
# =============================================================================

OB1_MCP_ACCESS_KEY=***
# openssl rand -hex 32
OB1_CITATION_URL=http://localhost:7981/thoughts
# URL твоего OB1-сервера. HTTP — ок, IP — ок.
# Это просто формирует ссылки в ответах инструментов.

# =============================================================================
# Honcho — User Model
# =============================================================================

HONCHO_REDIS_PASSWORD=***
HONCHO_JWT_SECRET=***
HONCHO_API_KEY=***

# =============================================================================
# Общие
# =============================================================================

LOG_LEVEL=INFO
