# Memory Layer — Unified Environment
# =============================================================================
# Единый .env для OB1 (knowledge base) + Honcho (user model).
# Один эмбеддер (Infinity + deepvk/USER-bge-m3) на двоих.
# Один LLM-ключ (DeepSeek) на всех.
#
# Порядок:
#   1. Скопировать этот файл в .env
#   2. Заменить *** на реальные значения
#   3. docker compose up -d

# =============================================================================
# Общие — LLM и эмбеддинги
# =============================================================================

# DeepSeek API (используется и OB1, и Honcho)
DEEPSEEK_API_KEY=***
DEEPSEEK_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Модель эмбеддингов (общая для обоих)
# deepvk/USER-bge-m3 — русский MTEB 0.706, 1024-dim
EMBEDDING_MODEL=deepvk/USER-bge-m3

# =============================================================================
# OB1 — Knowledge Base
# =============================================================================

OB1_DB_PASSWORD=***
OB1_MCP_ACCESS_KEY=***
# Сгенерировать: openssl rand -hex 32
OB1_CITATION_URL=https://openbrain.local/thoughts

# =============================================================================
# Honcho — User Model
# =============================================================================

HONCHO_DB_PASSWORD=***
HONCHO_REDIS_PASSWORD=***
HONCHO_JWT_SECRET=***
HONCHO_API_KEY=***

# =============================================================================
# Общие настройки
# =============================================================================

LOG_LEVEL=INFO
