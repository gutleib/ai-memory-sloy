# AI Memory Layer — Unified Environment
# =============================================================================
# Единый .env для OB1 (knowledge base) + Honcho (user model).
# Один PostgreSQL, один эмбеддер, один LLM-ключ.
# Вендор-агностик: DeepSeek по умолчанию, но заменимо на любой OpenAI-совместимый API.
#
# Порядок:
#   1. Скопировать этот файл в .env
#   2. Заменить *** на реальные значения
#   3. Выбрать DOMAIN (см. ниже)
#   4. docker compose up -d

# =============================================================================
# Домен (определяет URL всех сервисов)
# =============================================================================
# Три сценария — раскомментируй нужный:
#
# 1. Рабочая станция (только localhost):
DOMAIN=localhost
#
# 2. Локальная сеть (доступ с других машин):
# DOMAIN=ai.local
#   → добавить на клиентах в /etc/hosts: <IP-сервера> ai.local
#
# 3. VPS (реальный домен):
# DOMAIN=ваш-домен.com

# =============================================================================
# Версии образов (менять при обновлении)
# =============================================================================
IMAGE_PGVECTOR=pgvector/pgvector:pg17
IMAGE_REDIS=redis:8.2
IMAGE_INFINITY=michaelf34/infinity:0.0.77-cpu
IMAGE_CADDY=caddy:2-alpine

# =============================================================================
# LLM (OpenAI-совместимый API)
# =============================================================================
# По умолчанию DeepSeek. Для другого провайдера — поменять URL и модель.

LLM_API_KEY=***
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# =============================================================================
# Эмбеддинги
# =============================================================================

EMBEDDING_MODEL=deepvk/USER-bge-m3

# =============================================================================
# PostgreSQL (единый, базы ob1 + honcho)
# =============================================================================

PG_SUPERUSER_PASSWORD=***
OB1_DB_PASSWORD=***
HONCHO_DB_PASSWORD=***

# =============================================================================
# OB1 — Knowledge Base
# =============================================================================

OB1_MCP_ACCESS_KEY=***
# openssl rand -hex 32
OB1_CITATION_URL=https://localhost/ob1
# Для других сценариев замени localhost на свой DOMAIN.
# Это просто строка для формирования ссылок в ответах.

# =============================================================================
# Honcho — User Model
# =============================================================================

HONCHO_REDIS_PASSWORD=***
HONCHO_JWT_SECRET=***
HONCHO_API_KEY=***

# =============================================================================
# Общие
# =============================================================================

LOG_LEVEL=INFO
