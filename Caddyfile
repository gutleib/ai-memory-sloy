# AI Memory Layer — Caddy reverse proxy
# Домен задаётся через переменную DOMAIN в .env.
# Три сценария — один конфиг.

{
    # Для VPS (сценарий 3): раскомментируй email, Caddy получит сертификат от Let's Encrypt.
    # email your@email.com
}

{env.DOMAIN} {
    handle_path /ob1/* {
        reverse_proxy ob1-server:7981
    }

    handle_path /honcho/* {
        reverse_proxy honcho-api:8000
    }

    respond /health 200
}
